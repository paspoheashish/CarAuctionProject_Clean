using AuthService.Application.DTOs;
using AuthService.Application.Interfaces;
using AuthService.Application.Services;
using AuthService.Controllers;
using AuthService.Infrastructure.Clients;
using Microsoft.AspNetCore.Mvc;
using Moq;
using NUnit.Framework;
using System;
using Microsoft.Extensions.Configuration;

namespace AuthService.Test
{
    public class AuthServiceTests
    {
        [Test]
        public void JwtTokenService_Generates_Token()
        {
            var configMock = new Mock<IConfiguration>();
            configMock.Setup(c => c["Jwt:Key"]).Returns("supersecretkey1234567890_supersecret");
            configMock.Setup(c => c["Jwt:Issuer"]).Returns("issuer");
            configMock.Setup(c => c["Jwt:Audience"]).Returns("audience");

            var service = new JwtTokenService(configMock.Object);
            var token = service.GenerateToken(new UserValidationResponse { UserId = 1, Email = "a@b.com", Role = "User" });

            Assert.That(token, Is.Not.Null.And.Not.Empty);
        }

        [Test]
        public async System.Threading.Tasks.Task AuthorizationService_Calls_Client()
        {
            var clientMock = new Mock<IUserServiceClient>();
            clientMock.Setup(h => h.ValidateCredentials("a@b.com", "pwd")).ReturnsAsync(new UserValidationResponse { UserId = 1, Email = "a@b.com", Role = "User" });

            var auth = new AuthorizationService(clientMock.Object);
            var res = await auth.Authorize("a@b.com", "pwd");

            Assert.That(res, Is.Not.Null);
            Assert.That(res!.Email, Is.EqualTo("a@b.com"));
        }

        [Test]
        public async System.Threading.Tasks.Task AuthController_Login_Returns_Unauthorized_When_Invalid()
        {
            var authMock = new Mock<IAuthorizationService>();
            authMock.Setup(a => a.Authorize("x@x.com", "bad")).ReturnsAsync((UserValidationResponse?)null);

            var jwtMock = new Mock<IJwtTokenService>();
            var controller = new AuthController(authMock.Object, jwtMock.Object);

            var res = await controller.Login(new LoginRequest { Email = "x@x.com", Password = "bad" });

            Assert.That(res, Is.InstanceOf<UnauthorizedObjectResult>());
        }

        [Test]
        public async System.Threading.Tasks.Task AuthController_Login_Returns_Token_When_Valid()
        {
            var user = new UserValidationResponse { UserId = 2, Email = "u@u.com", Role = "Admin" };
            var authMock = new Mock<IAuthorizationService>();
            authMock.Setup(a => a.Authorize("u@u.com", "good")).ReturnsAsync(user);

            var jwtMock = new Mock<IJwtTokenService>();
            jwtMock.Setup(j => j.GenerateToken(user)).Returns("token123");

            var controller = new AuthController(authMock.Object, jwtMock.Object);

            var res = await controller.Login(new LoginRequest { Email = "u@u.com", Password = "good" });

            Assert.That(res, Is.InstanceOf<OkObjectResult>());
            var ok = (OkObjectResult)res;
            Assert.That(ok.Value, Is.TypeOf<LoginResponse>());
            var lr = (LoginResponse)ok.Value!;
            Assert.That(lr.Token, Is.EqualTo("token123"));
        }
    }
}
