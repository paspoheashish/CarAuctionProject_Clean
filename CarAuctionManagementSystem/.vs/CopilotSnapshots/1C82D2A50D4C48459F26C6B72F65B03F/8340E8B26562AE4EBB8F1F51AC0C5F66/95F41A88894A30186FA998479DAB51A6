using Microsoft.AspNetCore.Mvc;
using System.Reflection;

namespace ItemService.Test
{
    internal static class TestHelpers
    {
        public static object? GetOkValue(IActionResult result) => (result as OkObjectResult)?.Value;

        public static string? GetMessage(IActionResult result)
        {
            var obj = (result as ObjectResult)?.Value;
            if (obj == null) return null;
            var prop = obj.GetType().GetProperty("message", BindingFlags.IgnoreCase | BindingFlags.Public | BindingFlags.Instance);
            return prop?.GetValue(obj)?.ToString();
        }

        public static T? GetProp<T>(object? obj, string propName)
        {
            if (obj == null) return default;
            var p = obj.GetType().GetProperty(propName, BindingFlags.IgnoreCase | BindingFlags.Public | BindingFlags.Instance);
            if (p == null) return default;
            return (T?)p.GetValue(obj);
        }
    }
}
