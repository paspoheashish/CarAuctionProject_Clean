using System.Collections.Generic;
using System.Threading.Tasks;
using AuctionService.Application.Interfaces;
using AuctionService.Application.Services;
using AuctionService.Domain.Entities;
using Moq;
using NUnit.Framework;

namespace AuctionService.Test
{
    public class AuctionServiceTests
    {
        private Mock<IUnitOfWork> _uowMock = null!;
        private Mock<IItemServiceClient> _itemClientMock = null!;
        private Mock<IAuctionRepository> _auctionRepoMock = null!;
        private Mock<IBidRepository> _bidRepoMock = null!;
        private AuctionService.Application.Services.AuctionService _service = null!;

        [SetUp]
        public void Setup()
        {
            _uowMock = new Mock<IUnitOfWork>();
            _itemClientMock = new Mock<IItemServiceClient>();
            _auctionRepoMock = new Mock<IAuctionRepository>();
            _bidRepoMock = new Mock<IBidRepository>();

            _service = new AuctionService.Application.Services.AuctionService(_uowMock.Object, _itemClientMock.Object, _auctionRepoMock.Object, _bidRepoMock.Object);
        }

        [Test]
        public async Task StartAuctionAsync_CreatesAuction_When_VehicleExists_And_NoActiveAuction()
        {
            _itemClientMock.Setup(c => c.VehicleExists(1)).ReturnsAsync(true);
            _auctionRepoMock.Setup(r => r.GetActive(1, true)).ReturnsAsync((Auction?)null);

            var result = await _service.StartAuctionAsync(1);

            Assert.That(result.VehicleId, Is.EqualTo(1));
            Assert.That(result.IsActive, Is.True);
            _auctionRepoMock.Verify(r => r.Add(It.IsAny<Auction>()), Times.Once);
            _uowMock.Verify(u => u.SaveAsync(), Times.Once);
        }

        [Test]
        public void StartAuctionAsync_Throws_When_VehicleDoesNotExist()
        {
            _itemClientMock.Setup(c => c.VehicleExists(2)).ReturnsAsync(false);

            Assert.ThrowsAsync<Exception>(async () => await _service.StartAuctionAsync(2));
        }

        [Test]
        public void StartAuctionAsync_Throws_When_ActiveAuctionExists()
        {
            _itemClientMock.Setup(c => c.VehicleExists(3)).ReturnsAsync(true);
            _auctionRepoMock.Setup(r => r.GetActive(3, true)).ReturnsAsync(new Auction { Id = 9, VehicleId = 3, IsActive = true });

            Assert.ThrowsAsync<Exception>(async () => await _service.StartAuctionAsync(3));
        }

        [Test]
        public async Task CloseAuctionAsync_Closes_When_Active()
        {
            var auction = new Auction { Id = 10, IsActive = true };
            _auctionRepoMock.Setup(r => r.Get(10)).ReturnsAsync(auction);

            var result = await _service.CloseAuctionAsync(10);

            Assert.That(result.IsActive, Is.False);
            Assert.That(result.ClosedAt, Is.Not.Null);
            _uowMock.Verify(u => u.SaveAsync(), Times.Once);
        }

        [Test]
        public void CloseAuctionAsync_Throws_When_NotFound()
        {
            _auctionRepoMock.Setup(r => r.Get(11)).ReturnsAsync((Auction?)null);

            Assert.ThrowsAsync<Exception>(async () => await _service.CloseAuctionAsync(11));
        }

        [Test]
        public void CloseAuctionAsync_Throws_When_AlreadyClosed()
        {
            var auction = new Auction { Id = 12, IsActive = false };
            _auctionRepoMock.Setup(r => r.Get(12)).ReturnsAsync(auction);

            Assert.ThrowsAsync<Exception>(async () => await _service.CloseAuctionAsync(12));
        }

        [Test]
        public async Task PlaceBidAsync_Adds_Bid_When_Valid()
        {
            var auction = new Auction { Id = 20, IsActive = true, CurrentBid = 100m, Bids = new List<Bid>() };
            _auctionRepoMock.Setup(r => r.Get(20)).ReturnsAsync(auction);
            _bidRepoMock.Setup(b => b.GetBidsForAuction(20)).ReturnsAsync(new List<Bid>());

            var res = await _service.PlaceBidAsync(20, 150m, 77);

            Assert.That(res, Is.Not.Null);
            Assert.That(res!.CurrentBid, Is.EqualTo(150m));
            Assert.That(res.HighestBidder, Is.EqualTo(77));
            _uowMock.Verify(u => u.SaveAsync(), Times.Once);
        }

        [Test]
        public void PlaceBidAsync_Throws_When_AuctionNotFound()
        {
            _auctionRepoMock.Setup(r => r.Get(21)).ReturnsAsync((Auction?)null);

            Assert.ThrowsAsync<Exception>(async () => await _service.PlaceBidAsync(21, 200m, 88));
        }

        [Test]
        public void PlaceBidAsync_Throws_When_NotActive()
        {
            var auction = new Auction { Id = 22, IsActive = false, CurrentBid = 0m };
            _auctionRepoMock.Setup(r => r.Get(22)).ReturnsAsync(auction);

            Assert.ThrowsAsync<Exception>(async () => await _service.PlaceBidAsync(22, 10m, 5));
        }

        [Test]
        public void PlaceBidAsync_Throws_When_BidTooLow()
        {
            var auction = new Auction { Id = 23, IsActive = true, CurrentBid = 500m, Bids = new List<Bid>() };
            _auctionRepoMock.Setup(r => r.Get(23)).ReturnsAsync(auction);

            Assert.ThrowsAsync<Exception>(async () => await _service.PlaceBidAsync(23, 400m, 5));
        }

        [Test]
        public async Task GetAuctionAsync_Delegates_To_Repository()
        {
            var expected = new Auction { Id = 30 };
            _auctionRepoMock.Setup(r => r.GetAuctionWithBids(30)).ReturnsAsync(expected);

            var res = await _service.GetAuctionAsync(30);

            Assert.That(res, Is.SameAs(expected));
        }
    }
}
