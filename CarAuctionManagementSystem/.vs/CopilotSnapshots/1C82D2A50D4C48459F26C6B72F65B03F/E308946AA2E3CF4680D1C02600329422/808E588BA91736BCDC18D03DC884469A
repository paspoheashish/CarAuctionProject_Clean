using Moq;
using NUnit.Framework;
using System.Threading.Tasks;
using Microsoft.AspNetCore.Mvc;
using UserService.Application.Interfaces.Repositories;
using UserService.Application.DTOs;
using UserService.Application.Services;
using UserService.Domain.Entities;
using UserService.Controllers;

namespace UserService.Test
{
    [TestFixture]
    public class UsersControllerTests
    {
        private Mock<IUserRepository> _userRepositoryMock = null!;
        private Mock<UserService.Application.Interfaces.Repositories.IUnitOfWork> _unitOfWorkMock = null!;
        private UserService.Application.Services.UserService _service = null!;
        private UsersController _controller = null!;

        [SetUp]
        public void SetUp()
        {
            _userRepositoryMock = new Mock<IUserRepository>();
            _unitOfWorkMock = new Mock<UserService.Application.Interfaces.Repositories.IUnitOfWork>();
            _service = new UserService.Application.Services.UserService(_unitOfWorkMock.Object, _userRepositoryMock.Object);
            _controller = new UsersController(_service);
        }

        [Test]
        public async Task GetUser_ReturnsNotFound_WhenUserDoesNotExist()
        {
            _userRepositoryMock.Setup(r => r.GetByEmailAsync(It.IsAny<string>())).ReturnsAsync((User?)null);

            var result = await _controller.GetUser("no@no.com");

            Assert.That(result, Is.TypeOf<NotFoundObjectResult>());
            var obj = ((NotFoundObjectResult)result).Value!;
            var message = obj.GetType().GetProperty("message")!.GetValue(obj) as string;
            Assert.That(message, Is.EqualTo("User not found."));
        }

        [Test]
        public async Task GetUser_ReturnsOk_WhenUserFound()
        {
            var user = new User("F", "L", "u@d.com", "p");
            // set Id via reflection since property has private setter
            typeof(User).GetProperty("Id")!.SetValue(user, 123L);
            _userRepositoryMock.Setup(r => r.GetByEmailAsync("u@d.com")).ReturnsAsync(user);

            var result = await _controller.GetUser("u@d.com");

            Assert.That(result, Is.TypeOf<OkObjectResult>());
            var obj = ((OkObjectResult)result).Value!;
            var email = obj.GetType().GetProperty("Email")!.GetValue(obj) as string;
            var id = obj.GetType().GetProperty("Id")!.GetValue(obj);
            Assert.That(email, Is.EqualTo("u@d.com"));
            Assert.That(id, Is.EqualTo(123L));
        }

        [Test]
        public async Task Register_ReturnsConflict_WhenEmailAlreadyExists()
        {
            var dto = new CreateUserDto { FirstName = "A", LastName = "B", Email = "x@y.com", Password = "p" };
            _userRepositoryMock.Setup(r => r.GetByEmailAsync(dto.Email)).ReturnsAsync(new User("A", "B", dto.Email, dto.Password));

            var result = await _controller.Register(dto);

            Assert.That(result, Is.TypeOf<ConflictObjectResult>());
            var obj = ((ConflictObjectResult)result).Value!;
            var message = obj.GetType().GetProperty("message")!.GetValue(obj) as string;
            Assert.That(message, Is.EqualTo("Email already exists."));
        }

        [Test]
        public async Task Register_ReturnsOk_WhenNewUser()
        {
            var dto = new CreateUserDto { FirstName = "A", LastName = "B", Email = "new@e.com", Password = "p" };
            _userRepositoryMock.Setup(r => r.GetByEmailAsync(dto.Email)).ReturnsAsync((User?)null);
            _userRepositoryMock.Setup(r => r.AddAsync(It.IsAny<User>())).Returns(Task.CompletedTask).Callback<User>(u => { typeof(User).GetProperty("Id")!.SetValue(u, 99L); });
            _unitOfWorkMock.Setup(u => u.SaveAsync()).ReturnsAsync(1);

            var result = await _controller.Register(dto);

            Assert.That(result, Is.TypeOf<OkObjectResult>());
            var obj = ((OkObjectResult)result).Value!;
            var email = obj.GetType().GetProperty("Email")!.GetValue(obj) as string;
            var id = obj.GetType().GetProperty("Id")!.GetValue(obj);
            Assert.That(email, Is.EqualTo(dto.Email));
            Assert.That(id, Is.EqualTo(99L));
        }

        [Test]
        public async Task Validate_ReturnsUnauthorized_WhenInvalid()
        {
            var dto = new ValidateCredentialsDto { Email = "a@b.com", Password = "p" };
            _userRepositoryMock.Setup(r => r.GetByEmailAndPasswordAsync(dto.Email, dto.Password)).ReturnsAsync((User?)null);

            var result = await _controller.Validate(dto);

            Assert.That(result, Is.TypeOf<UnauthorizedObjectResult>());
            var obj = ((UnauthorizedObjectResult)result).Value!;
            var message = obj.GetType().GetProperty("message")!.GetValue(obj) as string;
            Assert.That(message, Is.EqualTo("Invalid User."));
        }

        [Test]
        public async Task Validate_ReturnsOk_WhenValid()
        {
            var user = new User("F", "L", "a@b.com", "p");
            typeof(User).GetProperty("Id")!.SetValue(user, 55L);
            _userRepositoryMock.Setup(r => r.GetByEmailAndPasswordAsync("a@b.com", "p")).ReturnsAsync(user);

            var dto = new ValidateCredentialsDto { Email = "a@b.com", Password = "p" };
            var result = await _controller.Validate(dto);

            Assert.That(result, Is.TypeOf<OkObjectResult>());
            var obj = ((OkObjectResult)result).Value!;
            var email = obj.GetType().GetProperty("email")!.GetValue(obj) as string;
            var userId = obj.GetType().GetProperty("userId")!.GetValue(obj);
            var role = obj.GetType().GetProperty("role")!.GetValue(obj) as string;

            Assert.That(email, Is.EqualTo("a@b.com"));
            Assert.That(userId, Is.EqualTo(55L));
            Assert.That(role, Is.EqualTo("User"));
        }
    }
}
